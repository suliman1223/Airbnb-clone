<% layout('/layouts/boilerplate') -%>

    <body>
        <div class="row">
            <div class="col-8 offset-2">
                <h1>
                    <%= user.title %>
                </h1>
                <br>



                <a href="/listing/<%= user._id %>/edit" text-decoration: none;">Edit Listing</a>
                <form action="/listing/<%= user._id %>?_method=DELETE" method="POST" style="display:inline;">
                    <button class="btn btn-danger">Delete Listing</button>
                    <br><br>
                </form>

            </div>

            <div class="card col-6 offset-2">
                <img src="<%= user.image %>" class="card-img-top-show" alt="listing image">
                <div class="car-body">
                    <p class="card-text"><b>

                            <i>
                                <%= user.owner.username %>
                            </i><br>
                            <%= user.description %><br>
                                $<%= user.price.toLocaleString("en-US") %><br>
                                    <%= user.location %><br>
                                        <%= user.country %>



                    </p>

                </div>

            </div>




        </div>

        <div class="col-8 offset-2 mt-3 mb-3">
            <% if (currUser) { %>


                <h1>Leave a Review</h1>
                <div class="mt-3">
                    <form action="/listing/<%= user._id %>/reviews" method="post" novalidate class="needs-validation">
                        
                            <label for="rating" class="form-label">Rating</label>
                            <input type="range" name="" min="1" max="5" id="rating" class="form-range">
                        
                        <div class="mt-3">

                        <fieldset class="starability-slot">
                            <legend>First rating:</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                                aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="review[rating]">5 stars</label>
                        </fieldset>
                        </div>
                        <div class="mt-3 mb-3">
                            <label for="comment" class="form-label">Comment:</label>
                            <textarea name="review[comment]" cols="80" rows="4" id="comment" class="form-control"
                                required></textarea>
                            <div class="invalid-feedback">please enter the comment</div>
                        </div>

                        <button class="btn btn-outline-dark" type="submit">Submit</button>
                    </form>
                    <% } %>
                        <div>
                            <p><b>All Reviews</b></p>
                            <div class="row fsds">

                                <%for (const element of user.reviews) {%>
                                    <div class="card col-5 ms-3 mb-3">
                                        <div class="card-body">
                                            <h5 class="card-title">@<%= element.author.username %>
                                            </h5>
                                              <p class="starability-result" data-rating="<%= element.rating %>">
                                               
                                            </p>
                                            <p class="card-text">
                                                <%= element.comment %>
                                            </p>
                                            
                                          
                                            <form method="post"
                                                action="/listing/<%= user._id %>/reviews/<%= element._id %>?_method=delete">
                                                <button class="btn btn-sm btn-danger">Delete</button>
                                            </form>
                                        </div>

                                    </div>

                                    <% }%>

                            </div>
                        </div>
                </div>

        </div>


    </body>