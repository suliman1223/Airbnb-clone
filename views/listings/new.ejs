<% layout('/layouts/boilerplate') -%>

    <body>
        <div class="row">

            <div class="col-8 offset-2">
                <h1>Create New Listing</h1>
                <br>
                <form action="/listings" method="POST">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title:</label>
                        <input type="text" id="title" name="title" class="form-control" required
                            placeholder="Enter the title here">
                    </div>
                    <div class="mb-3">
                        <label for="price" class="form-label">Price:</label>
                        <input type="number" id="price" name="price" class="form-control" required
                            placeholder="Enter the price here">
                    </div>
                    <div class="mb-3">
                         <label for="image" class="form-label">Image URL:</label>
                        <input type="url" id="image" name="image" class="form-control" required
                            placeholder="Enter the image URL here">
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description:</label>
                        <textarea id="description" name="description" cols="10" rows="3" class="form-control" required
                            placeholder="Enter the description here"></textarea>
                    </div>
                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="location" class="form-label">Location:</label>
                            <input type="text" id="location" name="location" class="form-control" required
                                placeholder="Enter the location here">
                        </div>
                        <div class="mb-3 col-md-8">
                            <label for="2country" class="form-label">Country:</label>
                            <input type="text" id="country" name="country" class="form-control" required
                                placeholder="Enter the country here">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Create Listing</button>
                    <br><br>
                </form>

            </div>
        </div>
    </body>